{
	"name": "getontime-ontime",
	"version": "5.4.0",
	"main": "/dist/index.js",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-getontime-ontime.git"
	},
	"type": "module",
	"scripts": {
		"prepare": "husky install",
		"dev": "yarn build:watch",
		"build": "rimraf dist && yarn build:main",
		"build:main": "tsc -p tsconfig.json",
		"build:watch": "tsc -p tsconfig.json --watch",
		"lint": "eslint ./src --ext .ts",
		"lint:raw": "eslint --ext .ts --ext .js --ignore-pattern dist --ignore-pattern pkg",
		"format": "prettier -w .",
		"package": "yarn build && companion-module-build"
	},
	"engines": {
		"node": "^22.8"
	},
	"dependencies": {
		"@companion-module/base": "~2.0.0",
		"@getontime/resolver": "4.3.0",
		"companion-module-utils": "0.5.0",
		"semver": "^7.7.2",
		"ws": "8.20.1"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.0",
		"@types/node": "^22.19.14",
		"@types/semver": "^7.7.1",
		"@types/ws": "8.18.1",
		"eslint": "^9.36.0",
		"husky": "9.1.7",
		"lint-staged": "16.0.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.44.1"
	},
	"lint-staged": {
		"*.{js,json,md}": [
			"run prettier --write"
		],
		"*.ts": [
			"run lint --fix"
		]
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"packageManager": "yarn@4.13.0"
}
